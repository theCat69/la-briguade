    "@opencode-ai/plugin": "^1.4.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.0",
    "@opencode-ai/sdk": "^1.4.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  },
  "license": "MIT"
