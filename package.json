{
  "name": "la-briguade",
  "version": "0.1.6",
  "description": "Opencode plugin — registers agents, skills, commands, and hooks at runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "la-briguade": "bin/la-briguade.js"
  },
  "scripts": {
