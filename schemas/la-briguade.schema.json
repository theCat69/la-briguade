{
  "$id": "https://unpkg.com/la-briguade@0.2.3/schemas/la-briguade.schema.json",
  "title": "la-briguade configuration",
  "description": "Configuration file for the la-briguade opencode plugin. Place as la-briguade.json or la-briguade.jsonc in your project root.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "model": {
      "type": "string",
      "maxLength": 200
    },
    "opus_enabled": {
      "type": "boolean"
    },
    "agents": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "maxLength": 200
          },
          "systemPromptSuffix": {
            "type": "string",
            "maxLength": 8000
          },
          "temperature": {
            "type": "number",
            "minimum": 0,
            "maximum": 2
          },
          "topP": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "topK": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "variant": {
            "type": "string",
            "maxLength": 100
          },
          "maxTokens": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "permission": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "anyOf": [
                {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "boolean"
                    },
                    {
                      "type": "number"
                    }
                  ]
                },
                {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "boolean"
                      },
                      {
                        "type": "number"
                      }
                    ]
                  }
                }
              ]
            }
          }
        },
        "additionalProperties": false
      }
    },
    "log_level": {
      "type": "string",
      "enum": [
        "off",
        "error",
        "warn",
        "info",
        "debug"
      ]
    }
  },
  "additionalProperties": false
}
